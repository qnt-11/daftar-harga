{
  "id": "daftar-harga-app",
  "name": "Daftar Harga Barang",
  "short_name": "Harga",
  "description": "Aplikasi pencatatan daftar harga eceran dan grosir",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "fullscreen",
    "standalone"
  ],
  "background_color": "#000000",
  "theme_color": "#000000",
  "orientation": "portrait-primary",
  "dir": "ltr",
  "lang": "id-ID",
  "categories": [
    "business",
    "productivity",
    "finance"
  ],
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Scan Barcode",
      "short_name": "Scan",
      "description": "Buka kamera untuk scan barang",
      "url": "./index.html?action=scan",
      "icons": [
        {
          "src": "icon-scan.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Buka Keranjang",
      "short_name": "Keranjang",
      "description": "Lihat total belanjaan",
      "url": "./index.html?action=cart",
      "icons": [
        {
          "src": "icon-cart.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "screenshot-1.png",
      "sizes": "1080x2340",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Daftar Harga Cepat dan Mudah"
    },
    {
      "src": "screenshot-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Tampilan di Layar Besar"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": [".xlsx"],
        "application/vnd.ms-excel": [".xls"]
      }
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+harga",
      "url": "./index.html?link=%s"
    }
  ]
}
